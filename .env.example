# Application
APP_NAME=claude-to-im
DEBUG=false

# Database
DATABASE_URL=sqlite:///sessions/database.db

# Session
DEFAULT_SESSION_ROOT=./sessions
SESSION_TIMEOUT_HOURS=24
MAX_SESSIONS_PER_IM=10

# Permissions (comma-separated)
ALLOWED_DIRECTORIES=D:/Codes,C:/Projects

# Claude SDK
ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TURNS=10

# Feishu
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_SEND_TOOL_MESSAGES=false

# Tool Permissions (comma-separated, empty = allow all tools)
# 留空表示允许所有工具（默认）
#
# 权限语法：
#   精确匹配：Bash, Read, Write, Edit, Glob, Grep, LSP
#   MCP 通配：mcp (允许所有 MCP 工具)
#   MCP 服务器：mcp:pencil, mcp:godot, mcp:ide (允许特定 MCP 服务器的所有工具)
#   MCP 嵌套：mcp:plugin:playwright (允许嵌套的 MCP 服务器)
#
# 工具分类：
#   核心：Bash, Read, Write, Edit, Glob, Grep, LSP
#   MCP 服务器：
#     - mcp:pencil (设计工具)
#     - mcp:godot (游戏引擎)
#     - mcp:ide (Jupyter 执行)
#     - mcp:plugin:playwright (浏览器自动化)
#     - mcp:4_5v_mcp (图像分析)
#   任务管理：TodoWrite, TaskUpdate, TaskList, TaskGet
#   AI 功能：Agent, Skill, AskUserQuestion
#
# 示例配置：
#
# 1. 允许所有工具（默认，推荐）
# ALLOWED_TOOLS=
#
# 2. 只允许核心工具，禁用所有 MCP 工具
# ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep,LSP,TodoWrite,TaskUpdate,AskUserQuestion
#
# 3. 允许核心工具 + 设计工具
# ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep,LSP,mcp:pencil,TodoWrite,TaskUpdate,AskUserQuestion
#
# 4. 允许核心工具 + 所有 MCP 工具
# ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep,LSP,mcp,TodoWrite,TaskUpdate,AskUserQuestion
#
# 5. 只读模式（禁止写入和执行）
# ALLOWED_TOOLS=Read,Glob,Grep,LSP
#
# 6. 禁用浏览器自动化，但允许其他工具
# ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep,LSP,mcp:pencil,mcp:godot,mcp:ide,TodoWrite,TaskUpdate,AskUserQuestion
#
ALLOWED_TOOLS=

# Resources
RESOURCE_CACHE_DAYS=7
MAX_FILE_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
